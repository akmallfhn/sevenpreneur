generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//////////////////
// Enumerations //
//////////////////

enum StatusEnum {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")

  @@map("status_enum")
}

enum LearningMethodEnum {
  ONLINE @map("online")
  ONSITE @map("onsite")
  HYBRID @map("hybrid")

  @@map("learning_method_enum")
}

enum CategoryEnum {
  COHORT   @map("cohort")
  PLAYLIST @map("playlist")
  AI       @map("ai")
  EVENT    @map("event")

  @@map("category_enum")
}

// Enumeration for the Transaction model (T*)

enum TStatusEnum {
  PENDING @map("pending")
  PAID    @map("paid")
  FAILED  @map("failed")

  @@map("t_status_enum")
}

// Enumeration for the AIChat model (C*)

enum CRoleEnum {
  USER      @map("user")
  ASSISTANT @map("assistant")

  @@map("c_role_enum")
}

// Enumeration for the BAAnswerSheet model (BA*)

enum BAPeriodEnum {
  ASESMEN_PERTAMA @map("asesmen_pertama")
  ASESMEN_KEDUA   @map("asesmen_kedua")
  ASESMEN_KETIGA  @map("asesmen_ketiga")

  @@map("ba_period_enum")
}

// Enumeration for the BDFinCostMTD model (Cost*)

enum CostCategoryEnum {
  // TODO: use actual values
  TODO @map("todo")

  @@map("cost_category_enum")
}

// Enumeration for the BDNorthStarIndicator model (NS*)

enum NSStatusEnum {
  ON_TRACK  @map("on_track")
  AT_RISK   @map("at_risk")
  OFF_TRACK @map("off_track")

  @@map("ns_status_enum")
}

// Enumeration for the User model

enum OccupationEnum {
  EMPLOYEE     @map("employee")
  ENTREPRENEUR @map("entrepreneur")
  STUDENT      @map("student")
  FREELANCE    @map("freelance")
  MILITARY     @map("military")
  UNEMPLOYED   @map("unemployed")

  @@map("occupation_enum")
}

enum RevenueEnum {
  BELOW_50M         @map("below_50m")
  BETWEEN_50M_100M  @map("between_50m_100m")
  BETWEEN_100M_500M @map("between_100m_500m")
  BETWEEN_500M_1B   @map("between_500m_1b")
  BETWEEN_1B_10B    @map("between_1b_10b")
  BETWEEN_10B_25B   @map("between_10b_25b")
  ABOVE_25B         @map("above_25b")

  @@map("revenue_enum")
}

enum NumEmployeeEnum {
  SMALL   @map("small")
  MEDIUM  @map("medium")
  LARGE   @map("large")
  XLARGE  @map("xlarge")
  XXLARGE @map("xxlarge")

  @@map("num_employee_enum")
}

enum LegalEntityEnum {
  CV               @map("cv")
  PT               @map("pt")
  PT_TBK           @map("pt_tbk")
  PERSERO          @map("persero")
  FIRMA            @map("firma")
  KOPERASI         @map("koperasi")
  YAYASAN          @map("yayasan")
  UD               @map("ud")
  NON_LEGAL_ENTITY @map("non_legal_entity")

  @@map("legal_entity_enum")
}

// Enumeration for the Article model (A*)

enum AStatusEnum {
  DRAFT       @map("draft")
  PUBLISHED   @map("published")
  UNPUBLISHED @map("unpublished")

  @@map("a_status_enum")
}

// Enumeration for the WAConversation model (WA*)

enum WALeadStatus {
  COLD @map("cold")
  WARM @map("warm")
  HOT  @map("hot")

  @@map("wa_lead_status")
}

// Enumeration for the WAChat model (WAC*)

enum WACDirection {
  INBOUND  @map("inbound")
  OUTBOUND @map("outbound")

  @@map("wac_direction")
}

enum WACSenderType {
  USER  @map("user")
  ADMIN @map("admin")

  @@map("wac_sender_type")
}

enum WACType {
  AUDIO       @map("audio")
  BUTTON      @map("button")
  CONTACTS    @map("contacts")
  DOCUMENT    @map("document")
  EDIT        @map("edit")
  IMAGE       @map("image")
  INTERACTIVE @map("interactive")
  LOCATION    @map("location")
  ORDER       @map("order")
  REACTION    @map("reaction")
  REVOKE      @map("revoke")
  STICKER     @map("sticker")
  SYSTEM      @map("system")
  TEXT        @map("text")
  UNSUPPORTED @map("unsupported")
  VIDEO       @map("video")

  @@map("wac_type")
}

enum WACStatus {
  SENT      @map("sent")
  DELIVERED @map("delivered")
  READ      @map("read")
  FAILED    @map("failed")

  @@map("wac_status")
}

// Enumeration for the WAAsset model (WAAsset*)

enum WAAssetType {
  AUDIO        @map("audio")
  AUDIO_VOICE  @map("audio_voice")
  DOCUMENT     @map("document")
  IMAGE        @map("image")
  STICKER      @map("sticker")
  STICKER_ANIM @map("sticker_anim")
  VIDEO        @map("video")

  @@map("wa_asset_type")
}

// Enumeration for the WAAlert model (WAA*)

enum WAAStatus {
  SCHEDULED @map("scheduled")
  SENT      @map("sent")
  DELIVERED @map("delivered")
  BOUNCED   @map("bounced")

  @@map("wa_alert_status")
}

////////////
// Models //
////////////

// Lookup tables

model Role {
  id         Int      @id @default(autoincrement()) @db.SmallInt
  name       String   @unique @db.VarChar()
  permission Int      @db.SmallInt
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()
  users      User[]

  @@map("roles")
}

model Industry {
  id            Int      @id @default(autoincrement()) @db.SmallInt
  industry_name String   @unique @db.VarChar()
  created_at    DateTime @default(now()) @db.Timestamptz()
  users         User[]

  @@map("industries")
}

model PhoneCountryCode {
  id           Int    @id @default(autoincrement()) @db.SmallInt
  country_name String @db.VarChar()
  phone_code   String @unique @db.VarChar()
  emoji        String @db.VarChar()
  users        User[]

  @@map("phone_country_codes")
}

model PaymentChannel {
  id           Int        @id @default(autoincrement()) @db.SmallInt
  label        String     @db.VarChar()
  code         String     @unique @db.VarChar()
  method       String     @db.VarChar()
  image        String     @db.VarChar()
  status       StatusEnum @default(ACTIVE)
  calc_percent Decimal    @db.Decimal(6, 4)
  calc_flat    Decimal    @db.Decimal(5, 0)
  calc_vat     Boolean    @db.Boolean

  @@map("payment_channels")
}

// User data

model User {
  id                       String                 @id @default(uuid()) @db.Uuid
  full_name                String                 @db.VarChar()
  email                    String                 @unique @db.VarChar()
  phone_country            PhoneCountryCode?      @relation(fields: [phone_country_id], references: [id])
  phone_country_id         Int?                   @db.SmallInt
  phone_number             String?                @db.VarChar()
  avatar                   String?                @db.VarChar()
  role                     Role                   @relation(fields: [role_id], references: [id])
  role_id                  Int                    @default(3) @db.SmallInt // General User
  status                   StatusEnum             @default(ACTIVE)
  date_of_birth            DateTime?              @db.Date
  business_name            String?                @db.VarChar()
  industry                 Industry?              @relation(fields: [industry_id], references: [id])
  industry_id              Int?                   @db.SmallInt
  business_description     String?                @db.Text
  occupation               OccupationEnum?
  yearly_revenue           RevenueEnum?
  total_employees          NumEmployeeEnum?
  company_profile_url      String?                @db.VarChar()
  business_age_years       Int?                   @db.Integer
  legal_entity_type        LegalEntityEnum?
  average_selling_price    Decimal?               @db.Decimal(12, 2)
  created_at               DateTime               @default(now()) @db.Timestamptz()
  updated_at               DateTime               @default(now()) @updatedAt @db.Timestamptz()
  last_login               DateTime               @default(now()) @updatedAt @db.Timestamptz()
  deleted_at               DateTime?              @db.Timestamptz()
  tokens                   Token[]
  deleted_cohorts          Cohort[]
  deleted_playlists        Playlist[]
  speaker_at               Learning[]
  speaker_in               EducatorPlaylist[]     @relation("host_playlist")
  transactions             Transaction[]
  cohorts                  UserCohort[]
  discussion_starters      DiscussionStarter[]
  discussion_replies       DiscussionReply[]
  submissions              Submission[]
  ba_answer_sheets         BAAnswerSheet[]
  playlists                UserPlaylist[]         @relation("watch_playlist")
  Event                    Event[]
  UserEvent                UserEvent[]
  ai_results               AIResult[]
  ai_conversations         AIConversation[]
  attendances              Attendance[]
  authored_articles        Article[]              @relation("author_article")
  reviewed_articles        Article[]              @relation("reviewer_article")
  bd_fin_revenue_mtds      BDFinRevenueMTD[]
  bd_fin_cost_mtds         BDFinCostMTD[]
  bd_north_star_indicators BDNorthStarIndicator[]
  wa_conversations         WAConversation[]       @relation("wa_conversation")
  wa_handleds              WAConversation[]       @relation("wa_handle")

  @@map("users")
}

model Token {
  id         Int      @id @default(autoincrement()) @db.Integer
  user       User     @relation(fields: [user_id], references: [id])
  user_id    String   @db.Uuid
  is_active  Boolean  @default(false) @db.Boolean
  token      String   @unique @db.Text
  created_at DateTime @default(now()) @db.Timestamptz()

  @@map("tokens")
}

// LMS-related

model Cohort {
  id            Int           @id @default(autoincrement()) @db.Integer
  name          String        @db.VarChar()
  description   String        @db.VarChar()
  image         String        @db.VarChar()
  image_banner  String        @db.VarChar()
  image_square  String        @db.VarChar()
  status        StatusEnum
  slug_url      String        @unique @db.VarChar()
  start_date    DateTime      @db.Timestamptz()
  end_date      DateTime      @db.Timestamptz()
  published_at  DateTime      @default(now()) @db.Timestamptz()
  updated_at    DateTime      @default(now()) @updatedAt @db.Timestamptz()
  deleted_at    DateTime?     @db.Timestamptz()
  deleted_by    User?         @relation(fields: [deleted_by_id], references: [id])
  deleted_by_id String?       @map("deleted_by") @db.Uuid
  cohort_prices CohortPrice[]
  modules       Module[]
  learnings     Learning[]
  projects      Project[]
  users         UserCohort[]

  @@map("cohorts")
}

model CohortPrice {
  id         Int          @id @default(autoincrement()) @db.Integer
  cohort     Cohort       @relation(fields: [cohort_id], references: [id])
  cohort_id  Int          @db.Integer
  name       String       @db.VarChar()
  amount     Decimal      @db.Decimal(12, 2)
  status     StatusEnum
  created_at DateTime     @default(now()) @db.Timestamptz()
  learnings  Learning[]
  users      UserCohort[]

  @@map("cohort_prices")
}

model Module {
  id           Int        @id @default(autoincrement()) @db.Integer
  cohort       Cohort     @relation(fields: [cohort_id], references: [id])
  cohort_id    Int        @db.Integer
  name         String     @db.VarChar()
  description  String?    @db.VarChar()
  document_url String     @db.VarChar()
  status       StatusEnum
  created_at   DateTime   @default(now()) @db.Timestamptz()
  updated_at   DateTime   @default(now()) @updatedAt @db.Timestamptz()

  @@map("modules")
}

model Learning {
  id                Int                 @id @default(autoincrement()) @db.Integer
  cohort            Cohort              @relation(fields: [cohort_id], references: [id])
  cohort_id         Int                 @db.Integer
  name              String              @db.VarChar()
  description       String              @db.VarChar()
  method            LearningMethodEnum
  meeting_date      DateTime            @default(now()) @db.Timestamptz()
  meeting_url       String?             @db.VarChar()
  location_name     String?             @db.VarChar()
  location_url      String?             @db.VarChar()
  speaker           User?               @relation(fields: [speaker_id], references: [id])
  speaker_id        String?             @db.Uuid
  recording_url     String?             @db.VarChar()
  external_video_id String?             @db.VarChar()
  price             CohortPrice?        @relation(fields: [price_id], references: [id])
  price_id          Int?                @db.Integer
  status            StatusEnum
  check_in          Boolean             @default(false) @db.Boolean
  check_out         Boolean             @default(false) @db.Boolean
  check_out_code    String?             @db.VarChar()
  feedback_form     String?             @db.VarChar()
  created_at        DateTime            @default(now()) @db.Timestamptz()
  updated_at        DateTime            @default(now()) @updatedAt @db.Timestamptz()
  materials         Material[]
  discussions       DiscussionStarter[]
  attendances       Attendance[]

  @@map("learnings")
}

model Material {
  id           Int        @id @default(autoincrement()) @db.Integer
  learning     Learning   @relation(fields: [learning_id], references: [id])
  learning_id  Int        @db.Integer
  name         String     @db.VarChar()
  description  String?    @db.VarChar()
  document_url String     @db.VarChar()
  status       StatusEnum
  created_at   DateTime   @default(now()) @db.Timestamptz()
  updated_at   DateTime   @default(now()) @updatedAt @db.Timestamptz()

  @@map("materials")
}

model DiscussionStarter {
  id          Int               @id @default(autoincrement()) @db.Integer
  user        User              @relation(fields: [user_id], references: [id])
  user_id     String            @db.Uuid
  learning    Learning          @relation(fields: [learning_id], references: [id])
  learning_id Int               @db.Integer
  message     String            @db.Text()
  created_at  DateTime          @default(now()) @db.Timestamptz()
  updated_at  DateTime          @default(now()) @updatedAt @db.Timestamptz()
  replies     DiscussionReply[]

  @@map("discussion_starters")
}

model DiscussionReply {
  id         Int               @id @default(autoincrement()) @db.Integer
  user       User              @relation(fields: [user_id], references: [id])
  user_id    String            @db.Uuid
  starter    DiscussionStarter @relation(fields: [starter_id], references: [id])
  starter_id Int               @db.Integer
  message    String            @db.Text()
  created_at DateTime          @default(now()) @db.Timestamptz()
  updated_at DateTime          @default(now()) @updatedAt @db.Timestamptz()

  @@map("discussion_replies")
}

model Project {
  id           Int          @id @default(autoincrement()) @db.Integer
  cohort       Cohort       @relation(fields: [cohort_id], references: [id])
  cohort_id    Int          @db.Integer
  name         String       @db.VarChar()
  description  String       @db.VarChar()
  document_url String?      @db.VarChar()
  deadline_at  DateTime     @default(now()) @db.Timestamptz()
  status       StatusEnum
  created_at   DateTime     @default(now()) @db.Timestamptz()
  updated_at   DateTime     @default(now()) @updatedAt @db.Timestamptz()
  submissions  Submission[]

  @@map("projects")
}

model Submission {
  id           Int      @id @default(autoincrement()) @db.Integer
  project      Project  @relation(fields: [project_id], references: [id])
  project_id   Int      @db.Integer
  submitter    User     @relation(fields: [submitter_id], references: [id])
  submitter_id String   @db.Uuid
  document_url String?  @db.VarChar()
  comment      String?  @db.Text
  is_favorite  Boolean  @default(false) @db.Boolean
  created_at   DateTime @default(now()) @db.Timestamptz()
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz()

  @@map("submissions")
}

model Attendance {
  learning     Learning  @relation(fields: [learning_id], references: [id])
  learning_id  Int       @db.Integer
  user         User      @relation(fields: [user_id], references: [id])
  user_id      String    @db.Uuid
  check_in_at  DateTime? @db.Timestamptz()
  check_out_at DateTime? @db.Timestamptz()

  @@id([learning_id, user_id])
  @@map("attendances")
}

// Business-assessment-related

model BACategory {
  id            Int             @id @default(autoincrement()) @db.SmallInt
  name          String          @db.VarChar()
  weight        Decimal         @db.Decimal(5, 2) // in percent (%)
  num_order     Int?            @db.SmallInt
  created_at    DateTime        @default(now()) @db.Timestamptz()
  updated_at    DateTime        @default(now()) @updatedAt @db.Timestamptz()
  subcategories BASubcategory[]

  @@map("ba_categories")
}

model BASubcategory {
  id          Int          @id @default(autoincrement()) @db.SmallInt
  category    BACategory   @relation(fields: [category_id], references: [id])
  category_id Int          @db.SmallInt
  name        String       @db.VarChar()
  num_order   Int?         @db.SmallInt
  created_at  DateTime     @default(now()) @db.Timestamptz()
  updated_at  DateTime     @default(now()) @updatedAt @db.Timestamptz()
  questions   BAQuestion[]

  @@map("ba_subcategories")
}

model BAQuestion {
  id             Int            @id @default(autoincrement()) @db.Integer
  subcategory    BASubcategory  @relation(fields: [subcategory_id], references: [id])
  subcategory_id Int            @db.SmallInt
  question       String         @db.VarChar()
  hint           String         @db.VarChar()
  weight         Decimal        @db.Decimal(4, 2)
  status         StatusEnum
  num_order      Int?           @db.SmallInt
  created_at     DateTime       @default(now()) @db.Timestamptz()
  updated_at     DateTime       @default(now()) @updatedAt @db.Timestamptz()
  answers        BAAnswerItem[]

  @@map("ba_questions")
}

model BAAnswerSheet {
  id         Int            @id @default(autoincrement()) @db.Integer
  user       User           @relation(fields: [user_id], references: [id])
  user_id    String         @db.Uuid
  period     BAPeriodEnum
  score      Decimal        @db.Decimal(5, 2) // in percent (%)
  created_at DateTime       @default(now()) @db.Timestamptz()
  updated_at DateTime       @default(now()) @updatedAt @db.Timestamptz()
  answers    BAAnswerItem[]

  @@map("ba_answer_sheets")
}

model BAAnswerItem {
  id          Int           @id @default(autoincrement()) @db.Integer
  sheet       BAAnswerSheet @relation(fields: [sheet_id], references: [id])
  sheet_id    Int           @db.Integer
  question    BAQuestion    @relation(fields: [question_id], references: [id])
  question_id Int           @db.Integer
  score       Int           @db.SmallInt // in [0, 5] range
  created_at  DateTime      @default(now()) @db.Timestamptz()
  updated_at  DateTime      @default(now()) @updatedAt @db.Timestamptz()

  @@map("ba_answer_items")
}

// Business-metric-related

model BDFinRevenueMTD {
  id         Int      @id @default(autoincrement()) @db.Integer
  user       User     @relation(fields: [user_id], references: [id])
  user_id    String   @db.Uuid
  year       Int      @db.SmallInt
  month      Int      @db.SmallInt
  amount     Decimal  @db.Decimal(12, 2)
  currency   String   @db.VarChar()
  by_product Json     @db.Json
  by_channel Json     @db.Json
  note       String?  @db.VarChar()
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()

  @@map("bd_fin_revenue_mtds")
}

model BDFinCostMTD {
  id         Int              @id @default(autoincrement()) @db.Integer
  user       User             @relation(fields: [user_id], references: [id])
  user_id    String           @db.Uuid
  year       Int              @db.SmallInt
  month      Int              @db.SmallInt
  amount     Decimal          @db.Decimal(12, 2)
  currency   String           @db.VarChar()
  category   CostCategoryEnum
  note       String?          @db.VarChar()
  created_at DateTime         @default(now()) @db.Timestamptz()
  updated_at DateTime         @default(now()) @updatedAt @db.Timestamptz()

  @@map("bd_fin_cost_mtds")
}

model BDNorthStarIndicator {
  id            Int              @id @default(autoincrement()) @db.Integer
  user          User             @relation(fields: [user_id], references: [id])
  user_id       String           @db.Uuid
  name          String           @db.VarChar()
  description   String           @db.Text
  annual_target Decimal          @db.Decimal(12, 2)
  unit          String           @db.VarChar()
  status        NSStatusEnum
  created_at    DateTime         @default(now()) @db.Timestamptz()
  updated_at    DateTime         @default(now()) @updatedAt @db.Timestamptz()
  mtds          BDNorthStarMTD[]

  @@map("bd_north_star_indicators")
}

model BDNorthStarMTD {
  id           Int                  @id @default(autoincrement()) @db.Integer
  indicator    BDNorthStarIndicator @relation(fields: [indicator_id], references: [id])
  indicator_id Int                  @db.Integer
  year         Int                  @db.SmallInt
  month        Int                  @db.SmallInt
  actual_value Decimal              @db.Decimal(12, 2)
  note         String?              @db.VarChar()
  created_at   DateTime             @default(now()) @db.Timestamptz()
  updated_at   DateTime             @default(now()) @updatedAt @db.Timestamptz()

  @@map("bd_north_star_mtds")
}

// Playlist-related

model Playlist {
  id                Int                @id @default(autoincrement()) @db.Integer
  name              String             @db.VarChar()
  tagline           String             @db.VarChar()
  description       String             @db.Text
  video_preview_url String             @db.VarChar()
  image_url         String             @db.VarChar()
  image_banner_url  String             @db.VarChar()
  image_square_url  String             @db.VarChar()
  price             Decimal            @db.Decimal(12, 2)
  status            StatusEnum
  slug_url          String             @db.VarChar()
  published_at      DateTime           @default(now()) @db.Timestamptz()
  updated_at        DateTime           @default(now()) @updatedAt @db.Timestamptz()
  deleted_at        DateTime?          @db.Timestamptz()
  deleted_by        User?              @relation(fields: [deleted_by_id], references: [id])
  deleted_by_id     String?            @map("deleted_by") @db.Uuid
  videos            Video[]
  users             UserPlaylist[]
  educators         EducatorPlaylist[]

  @@map("playlists")
}

model Video {
  id                Int        @id @default(autoincrement()) @db.Integer
  playlist          Playlist   @relation(fields: [playlist_id], references: [id])
  playlist_id       Int        @db.Integer
  name              String     @db.VarChar()
  description       String?    @db.Text
  duration          Int        @db.Integer
  image_url         String     @db.VarChar()
  video_url         String     @db.VarChar()
  num_order         Int        @default(0) @db.SmallInt
  external_video_id String     @db.VarChar()
  status            StatusEnum

  @@map("videos")
}

// Event-related

model Event {
  id            Int                @id @default(autoincrement()) @db.Integer
  name          String             @db.VarChar()
  description   String             @db.VarChar()
  image         String             @db.VarChar()
  status        StatusEnum
  slug_url      String             @unique @db.VarChar()
  start_date    DateTime           @db.Timestamptz()
  end_date      DateTime           @db.Timestamptz()
  method        LearningMethodEnum
  meeting_url   String?            @db.VarChar()
  location_name String?            @db.VarChar()
  location_url  String?            @db.VarChar()
  published_at  DateTime           @default(now()) @db.Timestamptz()
  updated_at    DateTime           @default(now()) @updatedAt @db.Timestamptz()
  deleted_at    DateTime?          @db.Timestamptz()
  deleted_by    User?              @relation(fields: [deleted_by_id], references: [id])
  deleted_by_id String?            @map("deleted_by") @db.Uuid
  event_prices  EventPrice[]
  UserEvent     UserEvent[]

  @@map("events")
}

model EventPrice {
  id         Int        @id @default(autoincrement()) @db.Integer
  event      Event      @relation(fields: [event_id], references: [id])
  event_id   Int        @db.Integer
  name       String     @db.VarChar()
  amount     Decimal    @db.Decimal(12, 2)
  status     StatusEnum
  created_at DateTime   @default(now()) @db.Timestamptz()

  @@map("event_prices")
}

// Template-related

model Template {
  id           Int        @id @default(autoincrement()) @db.Integer
  name         String     @db.VarChar()
  description  String?    @db.VarChar()
  image        String     @db.VarChar()
  document_url String     @db.VarChar()
  status       StatusEnum
  tags         String     @default("") @db.VarChar()
  created_at   DateTime   @default(now()) @db.Timestamptz()
  updated_at   DateTime   @default(now()) @updatedAt @db.Timestamptz()

  @@map("templates")
}

// AI-tool-related

model AITool {
  id          Int        @id @default(autoincrement()) @db.SmallInt
  name        String     @db.VarChar()
  description String?    @db.VarChar()
  slug_url    String     @db.VarChar()
  status      StatusEnum
  results     AIResult[]

  @@map("ai_tools")
}

model AIResult {
  id         String   @id @default(nanoid()) @db.Char(21)
  user       User     @relation(fields: [user_id], references: [id])
  user_id    String   @db.Uuid
  ai_tool    AITool   @relation(fields: [ai_tool_id], references: [id])
  ai_tool_id Int      @db.SmallInt
  name       String   @db.VarChar()
  result     Json     @db.Json
  is_done    Boolean  @default(false) @db.Boolean
  qstash_id  String?  @db.VarChar()
  created_at DateTime @default(now()) @db.Timestamptz()

  @@map("ai_results")
}

// AI-chat-related

model AIConversation {
  id         String   @id @default(nanoid()) @db.Char(21)
  user       User     @relation(fields: [user_id], references: [id])
  user_id    String   @db.Uuid
  name       String   @db.VarChar()
  is_done    Boolean  @default(true) @db.Boolean
  created_at DateTime @default(now()) @db.Timestamptz()
  chats      AIChat[]

  @@map("ai_conversations")
}

model AIChat {
  id         String         @id @default(nanoid()) @db.Char(21)
  conv       AIConversation @relation(fields: [conv_id], references: [id])
  conv_id    String         @db.Char(21)
  role       CRoleEnum
  message    String         @db.Text()
  created_at DateTime       @default(now()) @db.Timestamptz()

  @@map("ai_chats")
}

// Transaction-related

/**
 * The item_id column refers to
 * - cohort_prices.id if the category is cohort,
 * - playlists.id     if the category is playlist, or
 * - event_prices.id  if the category is event.
 */

model Discount {
  id           Int           @id @default(autoincrement()) @db.Integer
  name         String        @db.VarChar()
  code         String        @db.VarChar()
  category     CategoryEnum
  item_id      Int           @db.Integer
  calc_percent Decimal       @db.Decimal(7, 4)
  status       StatusEnum
  start_date   DateTime      @db.Timestamptz()
  end_date     DateTime      @db.Timestamptz()
  created_at   DateTime      @default(now()) @db.Timestamptz()
  updated_at   DateTime      @default(now()) @updatedAt @db.Timestamptz()
  transactions Transaction[]

  @@map("discounts")
}

model Transaction {
  id              String       @id @default(nanoid()) @db.Char(21)
  user            User         @relation(fields: [user_id], references: [id])
  user_id         String       @db.Uuid
  category        CategoryEnum
  item_id         Int          @db.Integer
  amount          Decimal      @db.Decimal(12, 2)
  discount        Discount?    @relation(fields: [discount_id], references: [id])
  discount_id     Int?         @db.Integer
  discount_amount Decimal      @default(0) @db.Decimal(12, 2)
  admin_fee       Decimal      @db.Decimal(12, 2)
  vat             Decimal      @db.Decimal(12, 2)
  currency        String       @db.VarChar()
  invoice_number  String       @db.VarChar()
  status          TStatusEnum
  payment_method  String       @db.VarChar()
  payment_channel String       @db.VarChar()
  paid_at         DateTime?    @db.Timestamptz()
  created_at      DateTime     @default(now()) @db.Timestamptz()
  updated_at      DateTime     @default(now()) @updatedAt @db.Timestamptz()

  @@map("transactions")
}

// Tickers

model Ticker {
  id         Int        @id @default(1)
  title      String     @db.VarChar()
  callout    String?    @db.VarChar()
  target_url String     @db.VarChar()
  status     StatusEnum
  start_date DateTime   @db.Timestamptz()
  end_date   DateTime   @db.Timestamptz()
  updated_at DateTime   @default(now()) @updatedAt @db.Timestamptz()

  @@map("ticker")
}

// Article-related

model ArticleCategory {
  id         Int        @id @default(autoincrement()) @db.SmallInt
  name       String     @db.VarChar()
  status     StatusEnum
  slug       String     @db.VarChar()
  created_at DateTime   @default(now()) @db.Timestamptz()
  articles   Article[]

  @@map("article_categories")
}

model Article {
  id           Int             @id @default(autoincrement()) @db.Integer
  title        String          @db.VarChar()
  insight      String          @db.VarChar()
  image_url    String          @db.VarChar()
  body_content Json            @db.Json
  status       AStatusEnum
  category     ArticleCategory @relation(fields: [category_id], references: [id])
  category_id  Int             @db.SmallInt
  keywords     String          @db.VarChar()
  author       User            @relation("author_article", fields: [author_id], references: [id])
  author_id    String          @db.Uuid
  reviewer     User            @relation("reviewer_article", fields: [reviewer_id], references: [id])
  reviewer_id  String          @db.Uuid
  slug_url     String          @db.VarChar()
  published_at DateTime        @default(now()) @db.Timestamptz()
  updated_at   DateTime        @default(now()) @updatedAt @db.Timestamptz()

  @@map("articles")
}

// Interstitial Ads

model InterstitialAd {
  id             Int        @id @default(1)
  title          String     @db.VarChar()
  call_to_action String?    @db.VarChar()
  target_url     String     @db.VarChar()
  image_desktop  String?    @db.VarChar()
  image_mobile   String?    @db.VarChar()
  status         StatusEnum
  start_date     DateTime   @db.Timestamptz()
  end_date       DateTime   @db.Timestamptz()
  updated_at     DateTime   @default(now()) @updatedAt @db.Timestamptz()

  @@map("interstitial_ads")
}

// WhatsApp-chat-related

model WAConversation {
  id           String       @id @default(nanoid()) @db.Char(21)
  user         User?        @relation("wa_conversation", fields: [user_id], references: [id])
  user_id      String?      @db.Uuid
  full_name    String       @db.VarChar()
  phone_number String       @db.VarChar()
  handler      User?        @relation("wa_handle", fields: [handler_id], references: [id])
  handler_id   String?      @db.Uuid
  lead_status  WALeadStatus @default(COLD)
  winning_rate Int          @default(0) @db.SmallInt
  note         String?      @db.VarChar()
  last_read    WAChat?      @relation("last_read", fields: [last_read_id], references: [id])
  last_read_id String?      @db.Char(21)
  created_at   DateTime     @default(now()) @db.Timestamptz()
  updated_at   DateTime     @default(now()) @updatedAt @db.Timestamptz()
  chats        WAChat[]
  alerts       WAAlert[]

  @@map("wa_conversations")
}

model WAChat {
  id           String           @id @default(nanoid()) @db.Char(21)
  conv         WAConversation   @relation(fields: [conv_id], references: [id])
  conv_id      String           @db.Char(21)
  wam_id       String           @db.VarChar()
  direction    WACDirection
  sender_type  WACSenderType
  reply_to     WAChat?          @relation("reply", fields: [reply_to_id], references: [id])
  reply_to_id  String?          @db.Char(21)
  type         WACType
  message      String           @db.VarChar()
  attachment   Json?            @db.Json
  status       WACStatus?
  sent_at      DateTime?        @db.Timestamptz()
  delivered_at DateTime?        @db.Timestamptz()
  read_at      DateTime?        @db.Timestamptz()
  failed_at    DateTime?        @db.Timestamptz()
  created_at   DateTime         @default(now()) @db.Timestamptz()
  updated_at   DateTime         @default(now()) @updatedAt @db.Timestamptz()
  conv_read    WAConversation[] @relation("last_read")
  replies      WAChat[]         @relation("reply")

  @@map("wa_chats")
}

model WAAsset {
  id         Int         @id @default(autoincrement())
  url        String      @db.VarChar()
  type       WAAssetType
  created_at DateTime    @default(now()) @db.Timestamptz()
  updated_at DateTime    @default(now()) @updatedAt @db.Timestamptz()

  @@map("wa_assets")
}

model WAAlert {
  id               Int            @id @default(autoincrement())
  conv             WAConversation @relation(fields: [conv_id], references: [id])
  conv_id          String         @db.Char(21)
  email_message_id String?        @unique @db.Text
  scheduled_at     DateTime       @db.Timestamptz()
  status           WAAStatus      @default(SCHEDULED)
  created_at       DateTime       @default(now()) @db.Timestamptz()
  updated_at       DateTime       @default(now()) @updatedAt @db.Timestamptz()

  @@map("wa_alerts")
}

// Relation Tables //

model UserCohort {
  user            User        @relation(fields: [user_id], references: [id])
  user_id         String      @db.Uuid
  cohort          Cohort      @relation(fields: [cohort_id], references: [id])
  cohort_id       Int         @db.Integer
  cohort_price    CohortPrice @relation(fields: [cohort_price_id], references: [id])
  cohort_price_id Int         @db.Integer
  certificate_url String?     @db.VarChar()
  is_scout        Boolean     @default(false) @db.Boolean

  @@id([user_id, cohort_id])
  @@map("users_cohorts")
}

model UserPlaylist {
  user        User     @relation("watch_playlist", fields: [user_id], references: [id])
  user_id     String   @db.Uuid
  playlist    Playlist @relation(fields: [playlist_id], references: [id])
  playlist_id Int      @db.Integer
  rating      Int?     @db.Integer
  review      String?  @db.VarChar()

  @@id([user_id, playlist_id])
  @@map("users_playlists")
}

model EducatorPlaylist {
  user        User     @relation("host_playlist", fields: [user_id], references: [id])
  user_id     String   @db.Uuid
  playlist    Playlist @relation(fields: [playlist_id], references: [id])
  playlist_id Int      @db.Integer

  @@id([user_id, playlist_id])
  @@map("educators_playlists")
}

model UserEvent {
  user     User   @relation(fields: [user_id], references: [id])
  user_id  String @db.Uuid
  event    Event  @relation(fields: [event_id], references: [id])
  event_id Int    @db.Integer

  @@id([user_id, event_id])
  @@map("users_events")
}

view UserTemplate {
  user_id String @db.Uuid

  @@map("users_templates")
}

view UserAITool {
  user_id String @db.Uuid

  @@map("users_ai_tools")
}

view UserAIChat {
  user_id String @db.Uuid

  @@map("users_ai_chats")
}
